---
import Base from '../layouts/Base.astro';
import PresenterPanel from '../components/work/PresenterPanel.tsx';
import { COMPANIES } from '../data/companies';
import { IDENTITY, SITE } from '../utils/constants';

const lite = COMPANIES.map((c) => ({ slug: c.slug, name: c.name, roleTitle: c.roleTitle, tagline: c.tagline, accent: c.accent }));
---

<Base>
  <section class="border-b border-line bg-grid">
    <div class="mx-auto max-w-5xl px-4 py-14 sm:py-16">
      <p class="mb-3 inline-flex items-center gap-2 rounded-full border border-line bg-ink-900/60 px-3 py-1 text-xs font-medium text-fog-400">
        <span class="h-1.5 w-1.5 rounded-full bg-mint"></span> {SITE.name} · control panel
      </p>
      <h1 class="text-3xl font-extrabold leading-tight text-fog-100 sm:text-4xl">
        One demo per job. Built from the actual job description.
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-fog-300">
        Instead of one generic portfolio, each target company gets its own working simulation of
        <em>that exact role</em> — its requirements mapped to a real task you can play. This page is your
        private hub: toggle which targets are active, open a simulation, or copy a clean per-company link
        to send a recruiter (they only ever see their own company).
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-12">
    <PresenterPanel client:load companies={lite} liveUrl={IDENTITY.liveUrl} />

    <!-- how it works -->
    <div class="mt-14">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-fog-500">How each simulation is tailored</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        <div class="rounded-xl border border-line bg-ink-900/40 p-5">
          <div class="font-mono text-2xl font-bold text-sky">01</div>
          <h3 class="mt-2 text-base font-semibold text-fog-100">Read the JD</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-fog-400">Each role’s requirements become a "Requirements → what this proves" map, so a recruiter sees their own words reflected.</p>
        </div>
        <div class="rounded-xl border border-line bg-ink-900/40 p-5">
          <div class="font-mono text-2xl font-bold text-sky">02</div>
          <h3 class="mt-2 text-base font-semibold text-fog-100">Do the real task</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-fog-400">A working console for that role: the actual work — diagnose, decide, escalate, write the deliverable — with reasoning recorded on every call.</p>
        </div>
        <div class="rounded-xl border border-line bg-ink-900/40 p-5">
          <div class="font-mono text-2xl font-bold text-sky">03</div>
          <h3 class="mt-2 text-base font-semibold text-fog-100">Prove the judgment</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-fog-400">A WorkProof Report scores the role’s competencies and shows how I’d handle each call — evidence, not claims.</p>
        </div>
      </div>
    </div>

    <p class="mt-12 text-center text-sm text-fog-500">
      Built by {IDENTITY.fullName} · <a href="/case-study" class="text-sky underline">how it’s built</a> · <a href="/resume" class="text-sky underline">resume</a>
    </p>
  </section>
</Base>
