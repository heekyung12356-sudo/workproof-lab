---
import Base from '../layouts/Base.astro';
import { HERO, CTAS, TARGET_ROLES, SITE } from '../utils/constants';

const steps = [
  {
    n: '01',
    title: 'Play the crisis',
    body: 'No login. Step into a Monday-morning ops crisis and make staffing, escalation, comms, and recovery calls under a live SLA clock.',
  },
  {
    n: '02',
    title: 'See your result',
    body: 'A deterministic rubric scores your calls across 6 ops dimensions — so you feel how realistic and demanding the scenario is.',
  },
  {
    n: '03',
    title: 'See how I’d handle it',
    body: 'Then read my reasoning for every decision — what I prioritized, what I traded off, and how it maps to a real ops team.',
  },
];
---

<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-line bg-grid">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-ink-950/40 to-ink-950"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:py-28">
      <p
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-line bg-ink-900/60 px-3 py-1 text-xs font-medium text-fog-400"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-mint"></span>
        {SITE.demoName} · {SITE.subtitle}
      </p>
      <h1 class="max-w-3xl text-4xl font-extrabold leading-[1.05] text-fog-100 sm:text-6xl">
        {HERO.lines.map((l) => <span class="block">{l}</span>)}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-fog-300 sm:text-lg">
        {HERO.sub}
      </p>

      <!-- 3 CTAs (§2) -->
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a
          href={CTAS.play.href}
          class="group rounded-xl bg-sky px-5 py-3.5 text-center font-semibold text-ink-950 shadow-lg shadow-sky/20 transition hover:opacity-90"
        >
          {CTAS.play.label}
          <span class="block text-[11px] font-normal text-ink-900/70">{CTAS.play.note}</span>
        </a>
        <a
          href={CTAS.commentary.href}
          class="rounded-xl border border-line bg-ink-850 px-5 py-3.5 text-center font-semibold text-fog-100 transition hover:border-fog-600"
        >
          {CTAS.commentary.label}
          <span class="block text-[11px] font-normal text-fog-500">{CTAS.commentary.note}</span>
        </a>
        <a
          href={CTAS.caseStudy.href}
          class="rounded-xl border border-line bg-ink-850 px-5 py-3.5 text-center font-semibold text-fog-100 transition hover:border-fog-600"
        >
          {CTAS.caseStudy.label}
          <span class="block text-[11px] font-normal text-fog-500">{CTAS.caseStudy.note}</span>
        </a>
      </div>
      <p class="mt-4 text-xs text-fog-600">
        Recruiter mode: no sign-up, no email wall. Link → crisis in one click.
      </p>
    </div>
  </section>

  <!-- TRUST SIGNALS -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-fog-500">
          What this proves
        </h2>
        <p class="mt-3 text-2xl font-bold text-fog-100">
          Not a pretty website — an understanding of how operations actually run.
        </p>
        <ul class="mt-5 space-y-3 text-sm text-fog-300">
          <li class="flex gap-2.5">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-sky"></span>
            Built on real ops mechanics: SLA tiers, an escalation matrix, and CSAT / AHT / FCR
            that move causally as you decide.
          </li>
          <li class="flex gap-2.5">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-sky"></span>
            A deterministic scoring rubric across prioritization, staffing, communication,
            escalation, documentation, and recovery.
          </li>
          <li class="flex gap-2.5">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-sky"></span>
            Transparent reasoning — every call comes with what I traded off, not a self-awarded grade.
          </li>
          <li class="flex gap-2.5">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-sky"></span>
            AI used as a controlled assistant; the deterministic engine stays the source of truth.
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-fog-500">
          Built for these roles
        </h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            TARGET_ROLES.map((r) => (
              <span class="rounded-full border border-line bg-ink-900/60 px-3 py-1.5 text-[13px] text-fog-300">
                {r}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- 3-step process -->
    <div class="mt-16">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-fog-500">How it works</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        {
          steps.map((s) => (
            <div class="rounded-xl border border-line bg-ink-900/40 p-5">
              <div class="font-mono text-2xl font-bold text-sky">{s.n}</div>
              <h3 class="mt-2 text-base font-semibold text-fog-100">{s.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-fog-400">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex justify-center">
      <a
        href={CTAS.play.href}
        class="rounded-xl bg-sky px-6 py-3.5 font-semibold text-ink-950 hover:opacity-90"
      >
        {CTAS.play.label} →
      </a>
    </div>
  </section>
</Base>
