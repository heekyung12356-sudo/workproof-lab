---
import Base from '../layouts/Base.astro';
import { COMMENTARY, COMMENTARY_CLOSING } from '../data/commentary';
import { IDENTITY } from '../utils/constants';
---

<Base
  title="How I'd Handle It — Architect's Commentary"
  description="My reasoning for every decision in the ops crisis — what I prioritized, what I traded off, the alternatives I rejected, and how each call maps to a real ops team."
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <header class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-wider text-fog-500">
        Architect's Commentary · core trust artifact
      </p>
      <h1 class="mt-1 text-3xl font-bold text-fog-100">How I'd handle it — and what I'd trade off</h1>
      <p class="mt-3 max-w-prose text-sm leading-relaxed text-fog-400">
        This is the real evidence — not a score I awarded myself. For each decision in the crisis, here's
        the call I made, why, <strong class="text-fog-200">what I gave up</strong>, the alternatives I
        rejected, and how it maps to a real ops team. Operations leadership is choosing which cost to pay
        under a clock, so the trade-offs are the point.
      </p>
      <div class="mt-4 flex flex-wrap gap-2 no-print">
        <a
          href="/demo/opsleader"
          class="rounded-lg border border-line bg-ink-850 px-3 py-1.5 text-[13px] font-semibold text-fog-200 hover:border-fog-600"
          >← Play the crisis first</a
        >
        <button
          id="print-btn"
          class="rounded-lg border border-sky/50 bg-sky/10 px-3 py-1.5 text-[13px] font-semibold text-sky hover:bg-sky/20"
          >Save as PDF (for interviews)</button
        >
      </div>
    </header>

    <div class="space-y-6">
      {
        COMMENTARY.map((b) => (
          <article class="print-card rounded-xl border border-line bg-ink-900/40 p-5">
            <div class="flex items-center gap-2">
              <span class="rounded bg-sky/15 px-2 py-0.5 font-mono text-[11px] font-bold text-sky">
                STEP {b.step}
              </span>
              <h2 class="text-lg font-bold text-fog-100">{b.title}</h2>
            </div>

            <div class="mt-3 space-y-3 text-sm leading-relaxed">
              <div>
                <div class="text-[11px] font-semibold uppercase tracking-wide text-mint">
                  The call I made
                </div>
                <p class="mt-1 text-fog-200">{b.call}</p>
              </div>

              <div>
                <div class="text-[11px] font-semibold uppercase tracking-wide text-fog-500 print-muted">
                  Why
                </div>
                <p class="mt-1 text-fog-300">{b.why}</p>
              </div>

              <div class="rounded-lg border border-amber/30 bg-amber/5 p-3">
                <div class="text-[11px] font-semibold uppercase tracking-wide text-amber">
                  What I traded off
                </div>
                <p class="mt-1 text-fog-200">{b.tradeoff}</p>
              </div>

              <div>
                <div class="text-[11px] font-semibold uppercase tracking-wide text-fog-500 print-muted">
                  Alternatives I considered & rejected
                </div>
                <ul class="mt-1.5 space-y-1.5">
                  {b.rejected.map((r) => (
                    <li class="text-fog-300">
                      <span class="text-fog-200">{r.option}</span>
                      <span class="text-fog-500"> — {r.reason}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div>
                <div class="text-[11px] font-semibold uppercase tracking-wide text-fog-500 print-muted">
                  How this maps to a real ops team
                </div>
                <p class="mt-1 text-fog-400">{b.realOps}</p>
              </div>

              <details class="rounded-lg border border-line bg-ink-850/50 p-2.5 no-print">
                <summary class="cursor-pointer text-[12px] font-semibold text-fog-500">
                  Interview STAR version
                </summary>
                <p class="mt-1.5 text-[13px] text-fog-300">{b.star}</p>
              </details>
            </div>
          </article>
        ))
      }
    </div>

    <section class="print-card mt-8 rounded-xl border border-line bg-ink-850/70 p-5">
      <h2 class="text-lg font-bold text-fog-100">{COMMENTARY_CLOSING.heading}</h2>
      <p class="mt-2 text-sm leading-relaxed text-fog-300">{COMMENTARY_CLOSING.body}</p>
      <div class="mt-4 flex flex-wrap gap-2 no-print">
        <a href="/case-study" class="rounded-lg bg-sky px-4 py-2.5 text-sm font-semibold text-ink-950 hover:opacity-90">
          Read the system case study →
        </a>
        <a
          href={`mailto:${IDENTITY.email}`}
          class="rounded-lg border border-line bg-ink-900 px-4 py-2.5 text-sm font-semibold text-fog-200 hover:border-fog-600"
        >
          Talk through the design live
        </a>
      </div>
    </section>
  </div>

  <script>
    document.getElementById('print-btn')?.addEventListener('click', () => window.print());
  </script>
</Base>
