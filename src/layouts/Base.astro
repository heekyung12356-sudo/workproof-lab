---
import '../styles/global.css';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import { SITE, IDENTITY, CF_ANALYTICS_TOKEN } from '../utils/constants';

interface Props {
  title?: string;
  description?: string;
  /** hide chrome (nav/footer) — used for full-bleed demo if needed */
  bare?: boolean;
  ogType?: string;
}

const {
  title,
  description = SITE.description,
  bare = false,
  ogType = 'website',
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.subtitle}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://workproof-lab.pages.dev').href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: SITE.demoName,
  description: SITE.description,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: IDENTITY.fullName, email: IDENTITY.email },
  url: IDENTITY.liveUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={IDENTITY.fullName} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content="/favicon.svg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Cloudflare Web Analytics — cookieless (§19). Active once token is set. */}
    {
      CF_ANALYTICS_TOKEN && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${CF_ANALYTICS_TOKEN}"}`}
        />
      )
    }
  </head>
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-3 focus:top-3 focus:z-50 focus:rounded focus:bg-sky focus:px-3 focus:py-2 focus:text-ink-950"
      >Skip to content</a
    >
    {!bare && <Nav />}
    <main id="main" class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
